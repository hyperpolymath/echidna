{"id":200097,"prover":"Isabelle","theorem":"blast_intro","goal":"\"\\<lbrakk> \\<forall>x. P x \\<longrightarrow> Q x; P a \\<rbrakk> \\<Longrightarrow> Q a\"","context":["blast","by"],"tactic_proof":"by blast","source":"tropical_resource_typing/isabelle_synthetic"}
