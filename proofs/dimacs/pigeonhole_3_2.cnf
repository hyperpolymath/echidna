c SPDX-License-Identifier: PMPL-1.0-or-later
c Pigeonhole: 3 pigeons in 2 holes (UNSAT)
c Variables: p_i_h means pigeon i in hole h; vars 1..6 for (1,1)(1,2)(2,1)(2,2)(3,1)(3,2)
c Each pigeon in some hole:
c   p_1 ∨ p_2, p_3 ∨ p_4, p_5 ∨ p_6
c No two pigeons in same hole:
c   ¬p_1 ∨ ¬p_3, ¬p_1 ∨ ¬p_5, ¬p_3 ∨ ¬p_5   (hole 1)
c   ¬p_2 ∨ ¬p_4, ¬p_2 ∨ ¬p_6, ¬p_4 ∨ ¬p_6   (hole 2)
p cnf 6 9
1 2 0
3 4 0
5 6 0
-1 -3 0
-1 -5 0
-3 -5 0
-2 -4 0
-2 -6 0
-4 -6 0
