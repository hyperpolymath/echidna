changes = [
  "src/zig_ffi/build.zig: added -Dstubs=<bool> option (default true) so both the shared and static libechidna_chapel_ffi bundle chapel_stubs.c. Pass -Dstubs=false when linking against the real libechidna_chapel built from chapel_poc/. Fixes chapel-ci.yml Job 3 (rust-chapel-feature) which previously downloaded a Zig lib with unresolved chapel_* externs.",
  "src/zig_ffi/build.zig: pass -fno-sanitize=undefined to the C stub compile; Zig defaults UBSan on for C and the __ubsan_* symbols are not in Rust's linker search path, which broke cargo test --features chapel.",
  "src/rust/proof_search.rs: pre-existing compile error fixed — anyhow::Context trait not in scope inside chapel_ffi submodule; added `use anyhow::Context;`. Without this `cargo build --features chapel` errored before reaching the link step.",
