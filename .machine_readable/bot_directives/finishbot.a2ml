# finishbot.a2ml — bot directive for finishbot

[bot]
name = "finishbot"
scope = "release readiness"

[permissions]
allow = ["release checklists", "docs updates", "metadata fixes"]
deny = ["code changes without approval"]

[notes]
guidance = "Focus on polish, licensing, and packaging"
