# sustainabot.a2ml — bot directive for sustainabot

[bot]
name = "sustainabot"
scope = "eco/economic standards"

[permissions]
allow = ["analysis", "reporting", "docs updates"]
deny = ["code changes without approval"]

[notes]
guidance = "Focus on measurement and recommendations"
