# seambot.a2ml — bot directive for seambot

[bot]
name = "seambot"
scope = "integration health"

[permissions]
allow = ["analysis", "contract checks", "docs updates"]
deny = ["code changes without approval"]

[notes]
guidance = "May add integration test suggestions"
