# glambot.a2ml — bot directive for glambot

[bot]
name = "glambot"
scope = "presentation + accessibility"

[permissions]
allow = ["docs", "readme badges", "ui/accessibility suggestions"]
deny = ["logic changes"]

[notes]
guidance = "Edits limited to presentation layers"
