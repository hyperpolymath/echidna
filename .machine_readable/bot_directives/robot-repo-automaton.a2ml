# robot-repo-automaton.a2ml — bot directive for robot-repo-automaton

[bot]
name = "robot-repo-automaton"
scope = "automated fixes"

[permissions]
allow = ["low-risk automated edits"]
deny = ["core logic changes without approval"]

[notes]
guidance = "Only apply fixes backed by explicit rule approval"
