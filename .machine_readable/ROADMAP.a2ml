# === DECISION LOG ===
# Archived decisions and rationales (reference only; not for active debate)

[decisions]

decision-echidna-structure = {
  date = "2026-04-25",
  decision = "Move echidna to top-level; echidnabot to gitbot-fleet; separate echidna-llm-mcp cartridge",
  rationale = "Echidna is a core estate service; echidnabot is a bot (belongs in gitbot-fleet); modularity requires independent cartridge repos",
  status = "APPROVED; implementation in progress"
}

decision-agentic-neurosym-conformance = {
  date = "2026-04-25",
  decision = "Populate AGENTIC.a2ml and NEUROSYM.a2ml with full spec conformance (gating, entropy, composition rules, proofs)",
  rationale = "Underlying impl is mature; A2ML declarations were stubs. Conformance closes the gap between what echidna does and what it claims to do",
  status = "APPROVED; completed 2026-04-25"
}

decision-zig-ffi-as-standard = {
  date = "2026-04-10",
  decision = "Zig as FFI layer; Idris2 as ABI formal proofs; Rust/SPARK as implementation",
  rationale = "Hyperpolymath standard (ABI/FFI universal); proven effective across echidna, standards-repo, IDApTIK",
  status = "APPROVED; active policy"
}

