;;
;; Assail Classifications — echidna
;; See panic-attack/.claude/CLAUDE.md § "User-Classification Registry".

(assail-classifications
  (metadata
    (version "1.0.0")
    (project "echidna")
    (last-updated "2026-05-26")
    (entries 2)
    (status "active"))

  ;; ─── PA021 ProofDrift — legitimate mathematical axioms ─────────────────
  ;; Both findings are postulates with inline justification in the source
  ;; (funext is HoTT-standard; Conflicts is an INTENTIONAL parameter not a
  ;; proof debt). See audits/audit-pa021-axioms-2026-05-26.md.

  (classification
    (file "proofs/agda/Basic.agda")
    (category "ProofDrift")
    (classification "legitimate-mathematical-axiom")
    (audit "audits/audit-pa021-axioms-2026-05-26.md §1")
    (rationale "funext: function extensionality, postulated in plain Agda (provable in Cubical Agda); standard mathematical axiom accepted by Coq, Lean, HoTT. Inline justification at line 172-177."))

  (classification
    (file "proofs/agda/SoundnessPreservation.agda")
    (category "ProofDrift")
    (classification "intentional-parameter")
    (audit "audits/audit-pa021-axioms-2026-05-26.md §2")
    (rationale "Conflicts is an abstract binary predicate parameter; the caller supplies a concrete proof of ¬ Conflicts when sets are disjoint. INTENTIONAL design parameter, not proof debt. Inline justification at line 44-53.")))
